# Copy to bi/lightdash/.env and adjust values.

# Postgres used by Lightdash internal metadata
PGUSER=lightdash
PGPASSWORD=lightdash
PGDATABASE=lightdash

# Required: random long secret used by Lightdash session/auth signing
LIGHTDASH_SECRET=change_me_to_a_long_random_secret

# Local dev defaults
# IMPORTANT: keep SITE_URL on container-internal app port (8080) so
# dashboard preview/export generation works from inside Lightdash workers.
SITE_URL=http://localhost:8080
HEADLESS_BROWSER_HOST=http://headless-browser:3000
SECURE_COOKIES=false
TRUST_PROXY=false
CUSTOM_VISUALIZATIONS_ENABLED=true
