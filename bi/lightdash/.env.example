# Copy to bi/lightdash/.env and adjust values.

# Postgres used by Lightdash internal metadata
PGUSER=lightdash
PGPASSWORD=lightdash
PGDATABASE=lightdash

# Required: random long secret used by Lightdash session/auth signing
LIGHTDASH_SECRET=change_me_to_a_long_random_secret

# Local dev defaults
SITE_URL=http://localhost:8080
SECURE_COOKIES=false
TRUST_PROXY=false

# S3-compatible object storage for query results / native pagination (MinIO by default)
S3_ENDPOINT=http://minio:9000
S3_BUCKET=lightdash-results
S3_REGION=eu-central-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
RESULTS_S3_BUCKET=lightdash-results
RESULTS_S3_REGION=eu-central-1
